{
  "name": "cafelive-kiosk",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "dev:mock": "vite --host --mode development",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "kiosk": "start \"\" \"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\" --kiosk http://localhost:3000",
    "kiosk:portrait": "start \"\" \"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\" --app=http://localhost:3000 --window-size=480,854 --window-position=100,50",
    "electron:dev": "concurrently --raw \"vite --host\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "i18next": "^25.8.18",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.1",
    "vite": "^6.4.1",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.bajaj.cafekiosk",
    "productName": "Cafe Kiosk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logos/bajajfinallogo.png"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    }
  }
}
